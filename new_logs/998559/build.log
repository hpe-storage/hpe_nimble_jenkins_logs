[2026-07-23T20:21:50.463Z]         /^ *\#/ {
[2026-07-23T20:21:50.463Z]             next
[2026-07-23T20:21:50.463Z]         }
[2026-07-23T20:21:50.463Z]         /^[^ \t]+/ {
[2026-07-23T20:21:50.464Z]             # get offset of first = in $0
[2026-07-23T20:21:50.464Z]             eq_idx = index($0, "=")
[2026-07-23T20:21:50.464Z]             # extract attr & value from $0
[2026-07-23T20:21:50.464Z]             attr = substr($0, 1, eq_idx - 1)
[2026-07-23T20:21:50.464Z]             value = substr($0, eq_idx + 1)
[2026-07-23T20:21:50.464Z]             # only need to strip trailing whitespace from attr
[2026-07-23T20:21:50.464Z]             sub(/[ \t]*$/, "", attr)
[2026-07-23T20:21:50.464Z]             # need to strip leading & trailing whitespace from value
[2026-07-23T20:21:50.464Z]             sub(/^[ \t]*/, "", value)
[2026-07-23T20:21:50.464Z]             sub(/[ \t]*$/, "", value)
[2026-07-23T20:21:50.464Z] 
[2026-07-23T20:21:50.464Z]             # cfg_attr_count: number of config lines per [section, attr]
[2026-07-23T20:21:50.464Z]             # cfg_attr: three dimensional array to keep all the config lines per [section, attr]
[2026-07-23T20:21:50.464Z]             # cfg_section: keep the section names in the same order as they appear in local.conf
[2026-07-23T20:21:50.464Z]             # cfg_sec_attr_name: keep the attr names in the same order as they appear in local.conf
[2026-07-23T20:21:50.464Z]             if (! (section, attr) in cfg_attr_count) {
