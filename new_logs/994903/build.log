[2026-07-23T01:47:34.681Z] +[38;5;242minc/meta-config:merge_config_file:97     (B[m awk -v 'configfile=$NOVA_CPU_CONF' '
[2026-07-23T01:47:34.681Z]         BEGIN {
[2026-07-23T01:47:34.681Z]             section = ""
[2026-07-23T01:47:34.681Z]             last_section = ""
[2026-07-23T01:47:34.681Z]             section_count = 0
[2026-07-23T01:47:34.681Z]         }
[2026-07-23T01:47:34.681Z]         /^\[.+\]/ {
[2026-07-23T01:47:34.681Z]             gsub("[][]", "", $1);
[2026-07-23T01:47:34.681Z]             section=$1
[2026-07-23T01:47:34.681Z]             next
[2026-07-23T01:47:34.681Z]         }
[2026-07-23T01:47:34.681Z]         /^ *\#/ {
[2026-07-23T01:47:34.681Z]             next
[2026-07-23T01:47:34.681Z]         }
[2026-07-23T01:47:34.681Z]         /^[^ \t]+/ {
[2026-07-23T01:47:34.681Z]             # get offset of first = in $0
[2026-07-23T01:47:34.681Z]             eq_idx = index($0, "=")
[2026-07-23T01:47:34.681Z]             # extract attr & value from $0
[2026-07-23T01:47:34.681Z]             attr = substr($0, 1, eq_idx - 1)
[2026-07-23T01:47:34.681Z]             value = substr($0, eq_idx + 1)
[2026-07-23T01:47:34.681Z]             # only need to strip trailing whitespace from attr
[2026-07-23T01:47:34.681Z]             sub(/[ \t]*$/, "", attr)
[2026-07-23T01:47:34.681Z]             # need to strip leading & trailing whitespace from value
[2026-07-23T01:47:34.681Z]             sub(/^[ \t]*/, "", value)
[2026-07-23T01:47:34.682Z]             sub(/[ \t]*$/, "", value)
[2026-07-23T01:47:34.682Z] 
[2026-07-23T01:47:34.682Z]             # cfg_attr_count: number of config lines per [section, attr]
[2026-07-23T01:47:34.682Z]             # cfg_attr: three dimensional array to keep all the config lines per [section, attr]
[2026-07-23T01:47:34.682Z]             # cfg_section: keep the section names in the same order as they appear in local.conf
[2026-07-23T01:47:34.682Z]             # cfg_sec_attr_name: keep the attr names in the same order as they appear in local.conf
[2026-07-23T01:47:34.682Z]             if (! (section, attr) in cfg_attr_count) {
[2026-07-23T01:47:34.682Z]                 if (section != last_section) {
[2026-07-23T01:47:34.682Z]                     cfg_section[section_count++] = section
[2026-07-23T01:47:34.682Z]                     last_section = section
[2026-07-23T01:47:34.682Z]                 }
[2026-07-23T01:47:34.682Z]                 attr_count = cfg_sec_attr_count[section_count - 1]++
[2026-07-23T01:47:34.682Z]                 cfg_sec_attr_name[section_count - 1, attr_count] = attr
[2026-07-23T01:47:34.682Z] 
[2026-07-23T01:47:34.682Z]                 cfg_attr[section, attr, 0] = value
[2026-07-23T01:47:34.682Z]                 cfg_attr_count[section, attr] = 1
[2026-07-23T01:47:34.682Z]             } else {
[2026-07-23T01:47:34.682Z]                 lno = cfg_attr_count[section, attr]++
[2026-07-23T01:47:34.682Z]                 cfg_attr[section, attr, lno] = value
[2026-07-23T01:47:34.682Z]             }
[2026-07-23T01:47:34.682Z]         }
[2026-07-23T01:47:34.682Z]         END {
[2026-07-23T01:47:34.682Z]             # Process each section in order
[2026-07-23T01:47:34.682Z]             for (sno = 0; sno < section_count; sno++) {
[2026-07-23T01:47:34.682Z]                 section = cfg_section[sno]
[2026-07-23T01:47:34.682Z]                 # The ini routines simply append a config item immediately
[2026-07-23T01:47:34.682Z]                 # after the section header. To keep the same order as defined
[2026-07-23T01:47:34.682Z]                 # in local.conf, invoke the ini routines in the reverse order
[2026-07-23T01:47:34.683Z]                 for (attr_no = cfg_sec_attr_count[sno] - 1; attr_no >=0; attr_no--) {
[2026-07-23T01:47:34.683Z]                     attr = cfg_sec_attr_name[sno, attr_no]
[2026-07-23T01:47:34.683Z]                     if (cfg_attr_count[section, attr] == 1)
[2026-07-23T01:47:34.683Z]                         print "iniset " configfile " " section " " attr " \"" cfg_attr[section, attr, 0] "\""
[2026-07-23T01:47:34.683Z]                     else {
[2026-07-23T01:47:34.683Z]                         # For multiline, invoke the ini routines in the reverse order
[2026-07-23T01:47:34.683Z]                         count = cfg_attr_count[section, attr]
[2026-07-23T01:47:34.683Z]                         print "inidelete " configfile " " section " " attr
[2026-07-23T01:47:34.683Z]                         print "iniset " configfile " " section " " attr " \"" cfg_attr[section, attr, count - 1] "\""
[2026-07-23T01:47:34.683Z]                         for (l = count -2; l >= 0; l--)
[2026-07-23T01:47:34.683Z]                             print "iniadd_literal " configfile " " section " " attr " \"" cfg_attr[section, attr, l] "\""
[2026-07-23T01:47:34.683Z]                     }
[2026-07-23T01:47:34.683Z]                 }
[2026-07-23T01:47:34.683Z]             }
