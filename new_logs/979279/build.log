[2026-07-23T10:34:10.816Z]         BEGIN {
[2026-07-23T10:34:10.816Z]             section = ""
[2026-07-23T10:34:10.816Z]             last_section = ""
[2026-07-23T10:34:10.816Z]             section_count = 0
[2026-07-23T10:34:10.816Z]         }
[2026-07-23T10:34:10.816Z]         /^\[.+\]/ {
[2026-07-23T10:34:10.816Z]             gsub("[][]", "", $1);
[2026-07-23T10:34:10.816Z]             section=$1
[2026-07-23T10:34:10.816Z]             next
[2026-07-23T10:34:10.816Z]         }
[2026-07-23T10:34:10.816Z]         /^ *\#/ {
[2026-07-23T10:34:10.816Z]             next
[2026-07-23T10:34:10.816Z]         }
[2026-07-23T10:34:10.816Z]         /^[^ \t]+/ {
[2026-07-23T10:34:10.816Z]             # get offset of first = in $0
[2026-07-23T10:34:10.816Z]             eq_idx = index($0, "=")
[2026-07-23T10:34:10.816Z]             # extract attr & value from $0
[2026-07-23T10:34:10.816Z]             attr = substr($0, 1, eq_idx - 1)
[2026-07-23T10:34:10.816Z]             value = substr($0, eq_idx + 1)
[2026-07-23T10:34:10.816Z]             # only need to strip trailing whitespace from attr
[2026-07-23T10:34:10.816Z]             sub(/[ \t]*$/, "", attr)
[2026-07-23T10:34:10.816Z]             # need to strip leading & trailing whitespace from value
[2026-07-23T10:34:10.816Z]             sub(/^[ \t]*/, "", value)
[2026-07-23T10:34:10.817Z]             sub(/[ \t]*$/, "", value)
[2026-07-23T10:34:10.817Z] 
[2026-07-23T10:34:10.817Z]             # cfg_attr_count: number of config lines per [section, attr]
[2026-07-23T10:34:10.817Z]             # cfg_attr: three dimensional array to keep all the config lines per [section, attr]
[2026-07-23T10:34:10.817Z]             # cfg_section: keep the section names in the same order as they appear in local.conf
[2026-07-23T10:34:10.817Z]             # cfg_sec_attr_name: keep the attr names in the same order as they appear in local.conf
[2026-07-23T10:34:10.817Z]             if (! (section, attr) in cfg_attr_count) {
[2026-07-23T10:34:10.817Z]                 if (section != last_section) {
[2026-07-23T10:34:10.817Z]                     cfg_section[section_count++] = section
[2026-07-23T10:34:10.817Z]                     last_section = section
[2026-07-23T10:34:10.817Z]                 }
[2026-07-23T10:34:10.817Z]                 attr_count = cfg_sec_attr_count[section_count - 1]++
[2026-07-23T10:34:10.817Z]                 cfg_sec_attr_name[section_count - 1, attr_count] = attr
[2026-07-23T10:34:10.817Z] 
[2026-07-23T10:34:10.817Z]                 cfg_attr[section, attr, 0] = value
[2026-07-23T10:34:10.817Z]                 cfg_attr_count[section, attr] = 1
[2026-07-23T10:34:10.817Z]             } else {
[2026-07-23T10:34:10.817Z]                 lno = cfg_attr_count[section, attr]++
[2026-07-23T10:34:10.817Z]                 cfg_attr[section, attr, lno] = value
[2026-07-23T10:34:10.817Z]             }
[2026-07-23T10:34:10.817Z]         }
[2026-07-23T10:34:10.817Z]         END {
[2026-07-23T10:34:10.817Z]             # Process each section in order
[2026-07-23T10:34:10.817Z]             for (sno = 0; sno < section_count; sno++) {
[2026-07-23T10:34:10.817Z]                 section = cfg_section[sno]
[2026-07-23T10:34:10.817Z]                 # The ini routines simply append a config item immediately
[2026-07-23T10:34:10.817Z]                 # after the section header. To keep the same order as defined
[2026-07-23T10:34:10.817Z]                 # in local.conf, invoke the ini routines in the reverse order
[2026-07-23T10:34:10.818Z]                 for (attr_no = cfg_sec_attr_count[sno] - 1; attr_no >=0; attr_no--) {
[2026-07-23T10:34:10.818Z]                     attr = cfg_sec_attr_name[sno, attr_no]
[2026-07-23T10:34:10.818Z]                     if (cfg_attr_count[section, attr] == 1)
[2026-07-23T10:34:10.818Z]                         print "iniset " configfile " " section " " attr " \"" cfg_attr[section, attr, 0] "\""
[2026-07-23T10:34:10.818Z]                     else {
[2026-07-23T10:34:10.818Z]                         # For multiline, invoke the ini routines in the reverse order
[2026-07-23T10:34:10.818Z]                         count = cfg_attr_count[section, attr]
[2026-07-23T10:34:10.818Z]                         print "inidelete " configfile " " section " " attr
[2026-07-23T10:34:10.818Z]                         print "iniset " configfile " " section " " attr " \"" cfg_attr[section, attr, count - 1] "\""
[2026-07-23T10:34:10.818Z]                         for (l = count -2; l >= 0; l--)
[2026-07-23T10:34:10.818Z]                             print "iniadd_literal " configfile " " section " " attr " \"" cfg_attr[section, attr, l] "\""
