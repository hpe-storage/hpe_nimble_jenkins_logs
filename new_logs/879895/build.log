[2026-07-24T20:10:53.578Z]         /^[^ \t]+/ {
[2026-07-24T20:10:53.578Z]             # get offset of first = in $0
[2026-07-24T20:10:53.578Z]             eq_idx = index($0, "=")
[2026-07-24T20:10:53.578Z]             # extract attr & value from $0
[2026-07-24T20:10:53.578Z]             attr = substr($0, 1, eq_idx - 1)
[2026-07-24T20:10:53.578Z]             value = substr($0, eq_idx + 1)
[2026-07-24T20:10:53.578Z]             # only need to strip trailing whitespace from attr
[2026-07-24T20:10:53.578Z]             sub(/[ \t]*$/, "", attr)
[2026-07-24T20:10:53.578Z]             # need to strip leading & trailing whitespace from value
[2026-07-24T20:10:53.578Z]             sub(/^[ \t]*/, "", value)
[2026-07-24T20:10:53.578Z]             sub(/[ \t]*$/, "", value)
