[2026-07-23T02:34:19.687Z]         /^[^ \t]+/ {
[2026-07-23T02:34:19.687Z]             # get offset of first = in $0
[2026-07-23T02:34:19.687Z]             eq_idx = index($0, "=")
[2026-07-23T02:34:19.687Z]             # extract attr & value from $0
[2026-07-23T02:34:19.687Z]             attr = substr($0, 1, eq_idx - 1)
[2026-07-23T02:34:19.687Z]             value = substr($0, eq_idx + 1)
[2026-07-23T02:34:19.687Z]             # only need to strip trailing whitespace from attr
[2026-07-23T02:34:19.687Z]             sub(/[ \t]*$/, "", attr)
[2026-07-23T02:34:19.687Z]             # need to strip leading & trailing whitespace from value
[2026-07-23T02:34:19.687Z]             sub(/^[ \t]*/, "", value)
[2026-07-23T02:34:19.687Z]             sub(/[ \t]*$/, "", value)
[2026-07-23T02:34:19.687Z] 
[2026-07-23T02:34:19.687Z]             # cfg_attr_count: number of config lines per [section, attr]
[2026-07-23T02:34:19.687Z]             # cfg_attr: three dimensional array to keep all the config lines per [section, attr]
