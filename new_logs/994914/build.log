[2026-07-22T21:51:49.314Z]         END {
[2026-07-22T21:51:49.314Z]             # Process each section in order
[2026-07-22T21:51:49.314Z]             for (sno = 0; sno < section_count; sno++) {
[2026-07-22T21:51:49.314Z]                 section = cfg_section[sno]
[2026-07-22T21:51:49.314Z]                 # The ini routines simply append a config item immediately
