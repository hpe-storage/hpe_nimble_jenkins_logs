[2026-07-22T21:51:49.314Z]             # cfg_attr_count: number of config lines per [section, attr]
[2026-07-22T21:51:49.314Z]             # cfg_attr: three dimensional array to keep all the config lines per [section, attr]
[2026-07-22T21:51:49.314Z]             # cfg_section: keep the section names in the same order as they appear in local.conf
