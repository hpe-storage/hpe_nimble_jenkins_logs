[2026-07-22T21:51:49.313Z]         }
[2026-07-22T21:51:49.313Z]         /^ *\#/ {
[2026-07-22T21:51:49.313Z]             next
[2026-07-22T21:51:49.313Z]         }
[2026-07-22T21:51:49.313Z]         /^[^ \t]+/ {
[2026-07-22T21:51:49.313Z]             # get offset of first = in $0
[2026-07-22T21:51:49.313Z]             eq_idx = index($0, "=")
[2026-07-22T21:51:49.313Z]             # extract attr & value from $0
[2026-07-22T21:51:49.313Z]             attr = substr($0, 1, eq_idx - 1)
[2026-07-22T21:51:49.313Z]             value = substr($0, eq_idx + 1)
[2026-07-22T21:51:49.313Z]             # only need to strip trailing whitespace from attr
[2026-07-22T21:51:49.313Z]             sub(/[ \t]*$/, "", attr)
[2026-07-22T21:51:49.314Z]             # need to strip leading & trailing whitespace from value
[2026-07-22T21:51:49.314Z]             sub(/^[ \t]*/, "", value)
[2026-07-22T21:51:49.314Z]             sub(/[ \t]*$/, "", value)
